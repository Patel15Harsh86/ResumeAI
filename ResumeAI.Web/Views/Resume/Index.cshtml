@model List<ResumeAI.Web.Models.ResumeViewModel>
@{
    ViewData["Title"] = "My Resumes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">My Resumes</h4>
</div>

<!-- Upload Card -->
<div class="card mb-4">
    <div class="card-body">
        <h6 class="fw-bold mb-3"><i class="bi bi-cloud-upload text-primary"></i> Upload New Resume</h6>
        <form asp-action="Upload" method="post" enctype="multipart/form-data" class="d-flex gap-3 align-items-end">
            <div class="flex-grow-1">
                <label class="form-label text-muted small">Select PDF or DOCX file (max 5MB)</label>
                <input type="file" name="file" class="form-control" accept=".pdf,.docx" required />
            </div>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-upload"></i> Upload
            </button>
        </form>
    </div>
</div>

<!-- Resumes List -->
<div class="card">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="fw-bold mb-0">All Resumes (@Model.Count)</h6>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-file-earmark-plus fs-1"></i>
                <p class="mt-3">No resumes uploaded yet. Upload your first resume above!</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>File Name</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Uploaded</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resume in Model)
                    {
                        <tr>
                            <td>
                                <i class="bi bi-file-earmark-@(resume.FileType == "PDF" ? "pdf text-danger" : "word text-primary")"></i>
                                @resume.FileName
                            </td>
                            <td><span class="badge bg-secondary">@resume.FileType</span></td>
                            <td>
                                <span class="badge @(resume.Status == "Analyzed" ? "bg-success" : resume.Status == "Parsed" ? "bg-info" : "bg-warning")">
                                    @resume.Status
                                </span>
                            </td>
                            <td class="text-muted small">@resume.UploadedAt.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Analyze" asp-route-id="@resume.Id" class="btn btn-outline-primary">
                                        <i class="bi bi-cpu"></i> Analyze
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@resume.Id" class="btn btn-outline-danger"
                                       onclick="return confirm('Delete this resume?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>