@model List<ResumeAI.Web.Models.InterviewSessionViewModel>
@{
    ViewData["Title"] = "Mock Interviews";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Mock Interviews</h4>
    <a asp-action="Start" class="btn btn-primary">
        <i class="bi bi-play-circle"></i> Start New Interview
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-mic fs-1"></i>
            <p class="mt-3">No interviews yet. Start your first mock interview!</p>
            <a asp-action="Start" class="btn btn-outline-primary">Start Interview</a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Job Title</th>
                        <th>Difficulty</th>
                        <th>Score</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@session.JobTitle</td>
                            <td>
                                <span class="badge @(session.Difficulty == "Hard" ? "bg-danger" : session.Difficulty == "Medium" ? "bg-warning" : "bg-success")">
                                    @session.Difficulty
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px; width: 80px;">
                                        <div class="progress-bar bg-primary" style="width: @session.TotalScore%"></div>
                                    </div>
                                    <span class="small fw-bold">@session.TotalScore</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(session.Status == "Completed" ? "bg-success" : "bg-warning")">
                                    @session.Status
                                </span>
                            </td>
                            <td class="text-muted small">@session.StartedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="Result" asp-route-id="@session.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View Result
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}